AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# Optional when using temporary credentials:
# AWS_SESSION_TOKEN=YOUR_AWS_SESSION_TOKEN

# Preferred region variable for Bedrock:
AWS_REGION=us-east-1


# Optional default Bedrock model for your own launch scripts:

# Sermon Metadata tab ΓåÆ Wix CMS (create-only)
# WIX_BEARER_TOKEN=your_preissued_bearer_token
# WIX_COLLECTION_ID=your_sermons_collection_guid
# WIX_SITE_ID=your_wix_site_id_metasite_id
# WIX_API_BASE=https://www.wixapis.com
# WIX_TITLE_FIELD=title   optional; set to your collection's primary display field key if different

# Blog Post tab ΓåÆ Wix Blog (draft posts). Same WIX_BEARER_TOKEN and WIX_SITE_ID as above.
# Blog scope required: SCOPE.DC-BLOG.MANAGE-BLOG
# WIX_BLOG_MEMBER_ID=site_member_guid   required for blog drafts; use site owner/member GUID (e.g. from Wix Dashboard ΓåÆ Members)
